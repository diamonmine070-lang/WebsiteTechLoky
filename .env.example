# Copy file này thành .env và điền giá trị thật

# Port server (Railway/Render tự set PORT)
PORT=3000

# JWT Secret - PHẢI đổi sang chuỗi random dài trước khi deploy
JWT_SECRET=thay-bang-chuoi-random-dai-it-nhat-32-ky-tu

# URL frontend được phép gọi API (CORS)
# Nhiều domain cách nhau bằng dấu phẩy
ALLOWED_ORIGINS=https://admin.techpulse.vn,https://techpulse.vn

# URL công khai của backend (dùng cho upload URL)
BASE_URL=https://api.techpulse.vn
